# --- Modalità di esecuzione ---
# Imposta su "local" per usare il LLM locale, "cloud" per Gemini
LLM_MODE=local

# --- Forzatura provider locale ---
# Opzionale: sovrascrive il provider scelto dalla matrix.json
# Valori: local_llamacpp, local_ollama, local_localai, google_gemini_flash, google_gemini_pro
LLM_PROVIDER=local_llamacpp

# --- Endpoint del LLM locale ---
# Per Docker Compose usa il nome del servizio (llama-server:8080)
# Per esecuzione nativa su localhost: http://localhost:8080
LLM_ENDPOINT_URL=http://llama-server:8080

# --- Chiave API per LLM locale (se richiesta) ---
LLM_API_KEY=sk-no-key-required

# --- Google Gemini (solo in modalità cloud) ---
GEMINI_API_KEY=

# --- OpenCode Server (per provider local_opencode) ---
# Basic auth per opencode serve (opzionale)
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=opencode

# --- OpenHands Agent Server (per provider local_openhands) ---
# API key per openhands agent_server (opzionale)
OPENHANDS_API_KEY=

# --- NanoClaw Gateway (Telegram bot) ---
# Token del bot Telegram (ottenuto da @BotFather)
TELEGRAM_TOKEN=
# Provider LLM predefinito per NanoClaw
NANOCLAW_PROVIDER=local_openhands
# Modalità predefinita per NanoClaw
NANOCLAW_MODE=local

# --- GitHub PAT (per push/PR su repo remoti) ---
STATE_REPO_PAT=
SOURCE_REPO_PAT=

# --- Docker Compose: modello llama.cpp ---
# Nome del file GGUF dentro ./models/
MODEL_FILE=llama-2-7b.Q4_K_M.gguf
# Layers GPU (0 = solo CPU)
N_GPU_LAYERS=0
# Dimensione contesto
CTX_SIZE=4096

# --- Docker Compose: task ---
EVENT_TYPE=git_automation
TASK_PAYLOAD=Routine check and code refactor

# --- Caveman Mode (token optimization) ---
# Attiva risposte concise: drop filler, keep substance, ~65% meno token output
# Contesto compresso: ~46% meno token input da CONTEXT.md
CAVEMAN_MODE=
